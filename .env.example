# URL usada apenas pelo servidor Next para buscar conteúdos e pelo proxy BFF.
# Em produção ela deve ser HTTPS e sem barra ao final.
CONCURSEIRO_API_URL=http://localhost:8080
NEXT_PUBLIC_WEB_URL=http://localhost:3000
NEXT_PUBLIC_APP_DOWNLOAD_URL=

# Defina como production no provedor de deploy. O build então recusa URLs
# ausentes, inválidas ou sem HTTPS para a API e a web.
CONCURSEIRO_DEPLOYMENT=

# Envia Web Vitals e erros sem dados pessoais para os endpoints internos de
# telemetria. Os logs JSON podem ser encaminhados pelo provedor de deploy.
NEXT_PUBLIC_TELEMETRY_ENABLED=false

# Segredo exclusivo do servidor para invalidar cache após uma publicação no
# painel administrativo. Nunca use o prefixo NEXT_PUBLIC_ nesta variável.
REVALIDATE_SECRET=
